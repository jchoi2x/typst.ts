{
  "name": "@jchoi2x/typst.solid",
  "version": "0.7.0",
  "description": "A SolidJS package for Typst integration.",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jchoi2x/typst.ts"
  },
  "bugs": {
    "url": "https://github.com/jchoi2x/typst.ts/issues"
  },
  "homepage": "https://github.com/jchoi2x/typst.ts",
  "scripts": {
    "build": "vite build",
    "publish:dry": "npm publish --dry-run --access public",
    "publish:lib": "npm publish --access public || exit 0",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@jchoi2x/typst-ts-renderer": "workspace:*",
    "@jchoi2x/typst.ts": "workspace:*",
    "solid-js": "^1.8.22",
    "vite-plugin-solid": "^2.11.6"
  },
  "keywords": [
    "solidjs",
    "typst",
    "typescript",
    "vite"
  ]
}